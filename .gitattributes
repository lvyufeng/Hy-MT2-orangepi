# Ensure shell scripts keep LF endings so the AscendC build toolchain
# (which is picky on Windows-CRLF) doesn't break.
*.sh text eol=lf
*.cpp text eol=lf
*.h   text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
# Vendored AscendC custom-op tooling from the CANN sample tree — keep its
# whitespace as-is so future upstream pulls don't churn the diff.
src/csrc/custom_ops/cmake/util/** -whitespace
